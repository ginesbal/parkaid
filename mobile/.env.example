
# mobile/.env
# copy this file to .env and fill in the values

# API configuration — your CurbFlow backend base URL.
#  - Production: your Render URL, e.g. https://curbflow-backend.onrender.com
#  - Local dev on a phone/emulator: http://<your-LAN-IP>:3000 (NOT "localhost")
EXPO_PUBLIC_API_URL=https://curbflow-backend.onrender.com

# Google Maps platform API key
# get your key from: https://console.cloud.google.com/apis/credentials
# make sure to enable all required APIs (see GOOGLE_MAPS_SETUP.md)
GOOGLE_MAPS_API_KEY=your_google_maps_key
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your_google_places_key

# Supabase (for direct queries if needed)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# Instructions:
# 1. copy this file: cp .env.example .env
# 2. replace all placeholder values with your actual credentials
# 3. never share your .env file or commit it to Git
# 4. after creating/modifying .env, restart Expo: npx expo start --clear