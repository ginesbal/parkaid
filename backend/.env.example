# CurbFlow backend environment — copy to .env and fill in DATABASE_URL.

# REQUIRED — the only variable the server needs to run.
# Supabase: Project -> Settings -> Database -> Connection string -> URI.
# Use the connection-pooler URI (host contains "pooler", port 6543).
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# ---------- Optional ----------

# Port to listen on. Hosts like Render set this automatically. Defaults to 3000.
# PORT=3000

# Enables the Google Places proxy (/api/places/*). Leave unset to disable that feature.
# GOOGLE_PLACES_API_KEY=

# Used only by `npm run setup` (loads Calgary Open Data). Works without a token at a lower rate limit.
# CALGARY_API_TOKEN=

# Set either of these to also write structured logs to a file (off by default).
# LOG_DIR=./logs
