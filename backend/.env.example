# parkaid backend environment — copy to .env and fill in DATABASE_URL.

# REQUIRED — the only variable the server needs to run.
# In Supabase -> Connect, use a POOLER URL (host contains "pooler.supabase.com",
# user "postgres.<ref>"). Use the "Session pooler" for a persistent server like
# this one. The pooler is IPv4; the "Direct connection" (db.<ref>.supabase.co)
# is IPv6-only and will NOT work on Render or other IPv4-only hosts.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ---------- Optional ----------

# Port to listen on. Hosts like Render set this automatically. Defaults to 3000.
# PORT=3000

# Enables the Google Places proxy (/api/places/*). Leave unset to disable that feature.
# GOOGLE_PLACES_API_KEY=

# Used only by `npm run setup` (loads Calgary Open Data). Works without a token at a lower rate limit.
# CALGARY_API_TOKEN=

# Set either of these to also write structured logs to a file (off by default).
# LOG_DIR=./logs
