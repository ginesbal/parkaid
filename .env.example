# CurbFlow — example environment files.
# The backend and mobile app each have their own .env (see below).

# ----- backend/.env -----
# The backend needs only ONE variable to run. See backend/.env.example for the
# full, authoritative template.
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@<region>.pooler.supabase.com:6543/postgres


# ----- mobile/.env -----
# copy this file to .env and fill in the values

# API Configuration
API_URL=http://YOUR_IP:3000

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key
EXPO_PUBLIC_GOOGLE_PLACES_KEY=your_google_places_key

# Supabase (for direct queries if needed)
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key